# PostgreSQL
POSTGRES_USER=autodetail
POSTGRES_PASSWORD=autodetail
POSTGRES_DB=autodetail
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://autodetail:autodetail@postgres:5432/autodetail
REDIS_URL=redis://redis:6379/0

# JWT (для prod сгенерировать через: openssl rand -hex 32)
JWT_SECRET=dev-secret-change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Среда
ENV=development
LOG_LEVEL=INFO

# SMTP (заглушка под Этап 3 - отправка КП клиенту)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@autodetail.local
SMTP_USE_TLS=true

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=/api/v1
